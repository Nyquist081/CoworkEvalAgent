LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
DATABASE_URL=sqlite+aiosqlite:///./coworkeval.db
JUDGE_CONCURRENCY=5
PASS_THRESHOLD=0.6

# Local Agent sidecar. The browser never receives API keys.
COWORKEVAL_CLAUDE_MODEL=haiku
COWORKEVAL_CLAUDE_MAX_BUDGET_USD=0.5
# Optional override. Leave unset to use scripts/claude_sidecar_wrapper.py.
# COWORKEVAL_CLAUDE_CODE_COMMAND=
